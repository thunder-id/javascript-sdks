# ThunderID IdP base URL (e.g. https://localhost:8090)
THUNDERID_BASE_URL=

# OAuth client credentials (from ThunderID console)
THUNDERID_CLIENT_ID=
THUNDERID_CLIENT_SECRET=

# Application UUID (from ThunderID console; required for branding, sign-up flow)
THUNDERID_APPLICATION_ID=

# HS256 key for signing session JWT cookies (min 32 chars)
# Generate with: openssl rand -base64 32
THUNDERID_SESSION_SECRET=
