THUNDERID_CLIENT_ID=your-client-id-here
THUNDERID_CLIENT_SECRET=your-client-secret-here
NEXT_PUBLIC_THUNDERID_APPLICATION_ID=your-application-id-here
THUNDERID_BASE_URL=https://localhost:8090
# Disables TLS verification for the local self-signed cert — remove in production
NODE_TLS_REJECT_UNAUTHORIZED=0
