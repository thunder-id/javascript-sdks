THUNDERID_CLIENT_ID=your-agent-client-id
THUNDERID_CLIENT_SECRET=your-agent-client-secret
THUNDERID_BASE_URL=https://localhost:8090
# Optional: space-separated scopes to request for this service.
THUNDERID_SCOPE=
# DANGER: Disables ALL TLS verification. Only for local development with self-signed certs. NEVER use in production.
NODE_TLS_REJECT_UNAUTHORIZED=0
