NUXT_PUBLIC_THUNDERID_BASE_URL=https://localhost:8090
NUXT_PUBLIC_THUNDERID_CLIENT_ID=your-client-id-here
THUNDERID_CLIENT_SECRET=your-client-secret-here
THUNDERID_SESSION_SECRET=generate-with-openssl-rand-base64-32
# Disables TLS verification for the local self-signed cert — remove in production
NODE_TLS_REJECT_UNAUTHORIZED=0
